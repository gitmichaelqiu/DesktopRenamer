    "By doing so, you can turn DesktopRenamer into a completely silent API app." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你可以将 DesktopRenamer 设置为纯 API 后台。"
          }
        }
      }
    },
    "Bypass native macOS animation lag. Enable trackpad overrides or hotkeys for instant, zero-delay switching." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "修复 macOS 原生桌面切换延迟。启用手势或快捷键覆盖换来更加快捷的切换体验。"
          }
        }
      }
    },
    "Cancel" : {
      "localizations" : {
        "zh-Hans" : {
