    "Adjust the position where the mouse grabs the window to move across spaces." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "调整鼠标抓窗口的位置，用于将窗口移动到不同桌面。"
          }
        }
      }
    },
    "Allow other apps to get space names." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许其他应用访问桌面名称。"
          }
        }
      }
    },
    "Are you a power user? Integrate directly with Raycast to manage and switch spaces elegantly via your favorite launcher." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "是个高级用户？在 Raycast 内直接控制你的桌面。"
          }
        }
      }
    },
    "Are you sure? This will delete all your space names and settings. The app will quit immediately." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清空所有的桌面和设置。App会立即退出。"
          }
        }
      }
    },
    "Automatically download updates" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自动下载更新"
          }
        }
      }
    },
    "Automatically rank commands" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自动排序命令"
          }
        }
      }
    },
    "Automatically rank commands based on their execution frequency. Turn off to manually reorder commands." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically rank commands based on their execution frequency. Turn off to manually reorder commands."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根据执行频率自动对命令进行排序。关闭以手动调整命令顺序。"
          }
        }
      }
    },
    "Automatically return to original space" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自动返回原桌面"
          }
        }
